        <control type="button" id="300">
            <left>80</left><top>1030</top><width>140</width><height>36</height>
            <texturefocus colordiffuse="FF3498db">white.png</texturefocus>
            <texturenofocus colordiffuse="88222233">white.png</texturenofocus>
            <label>$INFO[Window.Property(search_label)]</label>
