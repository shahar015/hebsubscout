<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol always="true">1000</defaultcontrol>
    <backgroundcolor>FF080810</backgroundcolor>
    <coordinates>
        <system>1</system>
    </coordinates>
    <controls>

        <!-- ════════════════════════════════════════════════════ -->
        <!-- HERO AREA (top half — fanart + gradient + info)     -->
        <!-- ════════════════════════════════════════════════════ -->

        <!-- Hero fanart backdrop -->
        <control type="image" id="100">
            <left>0</left><top>0</top><width>1920</width><height>540</height>
            <texture fallback="DefaultFanart.png">$INFO[Window.Property(hero_fanart)]</texture>
            <aspectratio>scale</aspectratio>
            <animation effect="fade" start="0" end="100" time="400">VisibleChange</animation>
        </control>

        <!-- Gradient overlay (transparent top → black bottom) -->
        <control type="image" id="101">
            <left>0</left><top>0</top><width>1920</width><height>540</height>
            <texture>gradient_hero.png</texture>
        </control>

        <!-- Hero title -->
        <control type="label" id="102">
            <left>80</left><top>360</top><width>900</width><height>45</height>
            <label>$INFO[Window.Property(hero_title)]</label>
            <font>font37</font>
            <textcolor>FFFFFFFF</textcolor>
            <shadowcolor>CC000000</shadowcolor>
        </control>

        <!-- Hero metadata (year • genres • rating) -->
        <control type="label" id="103">
            <left>80</left><top>410</top><width>900</width><height>28</height>
            <label>$INFO[Window.Property(hero_meta)]</label>
            <font>font13</font>
            <textcolor>FFaaaacc</textcolor>
            <shadowcolor>CC000000</shadowcolor>
        </control>

        <!-- Hero "Play" button -->
        <control type="button" id="200">
            <left>80</left><top>455</top><width>160</width><height>44</height>
            <texturefocus colordiffuse="FF2ecc71">white.png</texturefocus>
            <texturenofocus colordiffuse="88228B22">white.png</texturenofocus>
            <label>$INFO[Window.Property(hero_play_label)]</label>
            <font>font13_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FF000000</focusedcolor>
            <align>center</align>
            <aligny>center</aligny>
            <onright>201</onright>
            <ondown>1000</ondown>
        </control>

        <!-- Hero "Watchlist" button -->
        <control type="button" id="201">
            <left>260</left><top>455</top><width>200</width><height>44</height>
            <texturefocus colordiffuse="FF3498db">white.png</texturefocus>
            <texturenofocus colordiffuse="88333355">white.png</texturenofocus>
            <label>$INFO[Window.Property(hero_watchlist_label)]</label>
            <font>font13_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align>
            <aligny>center</aligny>
            <onleft>200</onleft>
            <ondown>1000</ondown>
        </control>

        <!-- ════════════════════════════════════════════════════ -->
        <!-- CONTENT ROWS (bottom half — scrollable poster rows) -->
        <!-- ════════════════════════════════════════════════════ -->

        <!-- Row container: vertical grouplist that holds all rows -->
        <control type="grouplist" id="9000">
            <left>0</left><top>530</top><width>1920</width><height>520</height>
            <orientation>vertical</orientation>
            <itemgap>0</itemgap>
            <pagecontrol>0</pagecontrol>
            <scrolltime tween="sine">300</scrolltime>
            <onup>200</onup>

            <!-- ── ROW 1: Continue Watching ── -->
            <control type="group" id="1100">
                <width>1920</width><height>104</height>
                <visible>!String.IsEmpty(Window.Property(row0_visible))</visible>
                <!-- Row label -->
                <control type="label" id="1001">
                    <left>80</left><top>0</top><width>600</width><height>30</height>
                    <label>$INFO[Window.Property(row0_label)]</label>
                    <font>font13_title</font>
                    <textcolor>FFccccdd</textcolor>
                </control>
            </control>
            <control type="fixedlist" id="1000">
                <left>72</left><width>1848</width><height>210</height>
                <visible>!String.IsEmpty(Window.Property(row0_visible))</visible>
                <orientation>horizontal</orientation>
                <movement>1</movement>
                <focusposition>0</focusposition>
                <scrolltime tween="sine">200</scrolltime>
                <onup>200</onup>
                <ondown>1010</ondown>
                <itemlayout width="195" height="200">
                    <control type="image">
                        <left>5</left><top>0</top><width>185</width><height>278</height>
                        <texture fallback="DefaultVideo.png">$INFO[ListItem.Art(poster)]</texture>
                        <aspectratio>scale</aspectratio>
                        <colordiffuse>CC999999</colordiffuse>
                    </control>
                </itemlayout>
                <focusedlayout width="195" height="200">
                    <control type="image">
                        <left>5</left><top>0</top><width>185</width><height>278</height>
                        <texture fallback="DefaultVideo.png">$INFO[ListItem.Art(poster)]</texture>
                        <aspectratio>scale</aspectratio>
                    </control>
                    <!-- Focus border -->
                    <control type="image">
                        <left>3</left><top>-2</top><width>189</width><height>282</height>
                        <texture border="3" colordiffuse="FF2ecc71">white.png</texture>
                    </control>
                    <animation effect="zoom" center="auto" start="100" end="105" time="150" tween="sine">Focus</animation>
                </focusedlayout>
            </control>

