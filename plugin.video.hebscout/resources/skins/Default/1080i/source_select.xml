        <control type="button" id="3007">
            <left>303</left><top>68</top><width>100</width><height>36</height>
            <label>Size</label><font>font12</font>
            <texturefocus colordiffuse="FF444466">white.png</texturefocus>
            <texturenofocus colordiffuse="FF222240">white.png</texturenofocus>
            <textcolor>FFcccccc</textcolor><focusedcolor>FFffffff</focusedcolor>
            <onleft>3006</onleft><onright>3008</onright><onup>3001</onup><ondown>3009</ondown>
