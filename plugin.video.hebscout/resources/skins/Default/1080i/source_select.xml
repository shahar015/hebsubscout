        <control type="button" id="3005">
            <left>542</left><top>22</top><width>90</width><height>36</height>
            <label>SD</label><font>font12</font>
            <texturefocus colordiffuse="FF444466">white.png</texturefocus>
            <texturenofocus colordiffuse="FF222240">white.png</texturenofocus>
            <textcolor>FFcccccc</textcolor><focusedcolor>FFffffff</focusedcolor>
            <onleft>3004</onleft><ondown>3006</ondown>
