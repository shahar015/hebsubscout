        <!-- Row 2: Sort label + buttons (labels set by Python) -->
        <control type="label" id="4002">
            <left>40</left><top>73</top><width>100</width><height>30</height>
            <label></label><font>font12</font>
        </control>
        <control type="button" id="3006">
            <left>150</left><top>68</top><width>145</width><height>36</height>
