            <font>font10</font><textcolor>FF555570</textcolor>
        </control>

        <control type="button" id="3009">
            <left>148</left><top>121</top><width>140</width><height>38</height>
            <label>Torrentio</label><font>font12</font>
            <texturefocus colordiffuse="FF1e1e30">white.png</texturefocus>
            <texturenofocus colordiffuse="FF12121e">white.png</texturenofocus>
            <textcolor>FF666680</textcolor><focusedcolor>FFffffff</focusedcolor>
            <onright>3010</onright><onup>3006</onup><ondown>1000</ondown>
        </control>
        <control type="button" id="3010">
            <left>296</left><top>121</top><width>140</width><height>38</height>
            <label>MediaFusion</label><font>font12</font>
            <texturefocus colordiffuse="FF1e1e30">white.png</texturefocus>
            <texturenofocus colordiffuse="FF12121e">white.png</texturenofocus>
            <textcolor>FF666680</textcolor><focusedcolor>FFffffff</focusedcolor>
            <onleft>3009</onleft><onup>3006</onup><ondown>1000</ondown>
