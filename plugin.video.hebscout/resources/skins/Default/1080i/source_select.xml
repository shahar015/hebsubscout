        <!-- Source count -->
        <control type="label" id="1001">
            <left>50</left><top>172</top><width>300</width><height>22</height>
            <label></label>
            <font>font10</font><textcolor>FF444460</textcolor>
        </control>

        <!-- Subtle divider -->
        <control type="image">
            <left>50</left><top>196</top><width>1160</width><height>1</height>
            <texture colordiffuse="FF1a1a2a">white.png</texture>
        </control>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SOURCE LIST                                               -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <control type="list" id="1000">
            <left>50</left><top>206</top><width>1160</width><height>855</height>
            <onup>3009</onup>
            <viewtype label="sources">list</viewtype>
            <pagecontrol>0</pagecontrol>
            <scrolltime>200</scrolltime>
            <itemgap>4</itemgap>

            <!-- ─── UNFOCUSED CARD ─── -->
            <itemlayout width="1160" height="104">
                <!-- Card bg -->
                <control type="image">
                    <left>0</left><top>2</top><width>1160</width><height>100</height>
                    <texture colordiffuse="FF0f0f1a">white.png</texture>
                </control>
                <!-- Quality badge -->
                <control type="image">
                    <left>0</left><top>2</top><width>82</width><height>100</height>
                    <texture colordiffuse="$INFO[ListItem.Property(quality_color)]">white.png</texture>
                </control>
                <!-- Quality badge darkened overlay for subtlety -->
                <control type="image">
                    <left>0</left><top>2</top><width>82</width><height>100</height>
                    <texture colordiffuse="88000000">white.png</texture>
                </control>
                <control type="label">
                    <left>0</left><top>36</top><width>82</width><height>30</height>
                    <label>$INFO[ListItem.Property(quality)]</label>
                    <font>font13</font><textcolor>FFffffff</textcolor>
                    <aligny>center</aligny><align>center</align>
                </control>
                <!-- Provider -->
                <control type="label">
                    <left>100</left><top>10</top><width>300</width><height>20</height>
                    <label>$INFO[ListItem.Property(provider)]</label>
                    <font>font10</font><textcolor>FF555570</textcolor>
                </control>
                <!-- Sub match -->
                <control type="label">
                    <left>850</left><top>8</top><width>290</width><height>24</height>
                    <label>$INFO[ListItem.Property(sub_display)]</label>
                    <font>font12</font><align>right</align>
                </control>
                <!-- Filename -->
                <control type="label">
                    <left>100</left><top>32</top><width>1040</width><height>22</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font10</font><textcolor>FFaaaabc</textcolor>
                </control>
                <!-- Tags -->
                <control type="label">
                    <left>100</left><top>56</top><width>800</width><height>18</height>
                    <label>$INFO[ListItem.Property(info_tags)]</label>
                    <font>font10</font><textcolor>FF444460</textcolor>
                </control>
                <!-- Size row -->
                <control type="label">
                    <left>100</left><top>76</top><width>800</width><height>18</height>
                    <label>$INFO[ListItem.Property(size_display)]</label>
                    <font>font10</font><textcolor>FF3a3a50</textcolor>
                </control>
            </itemlayout>

            <!-- ─── FOCUSED CARD ─── -->
            <focusedlayout width="1160" height="104">
                <!-- Focus glow border -->
                <control type="image">
                    <left>-2</left><top>0</top><width>1164</width><height>104</height>
                    <texture colordiffuse="$INFO[ListItem.Property(quality_color)]">white.png</texture>
                    <visible>Control.HasFocus(1000)</visible>
                </control>
                <!-- Card bg (brighter) -->
                <control type="image">
                    <left>0</left><top>2</top><width>1160</width><height>100</height>
                    <texture colordiffuse="FF16162a">white.png</texture>
                </control>
                <!-- Quality badge (full color when focused) -->
                <control type="image">
                    <left>0</left><top>2</top><width>82</width><height>100</height>
                    <texture colordiffuse="$INFO[ListItem.Property(quality_color)]">white.png</texture>
                </control>
                <control type="label">
                    <left>0</left><top>36</top><width>82</width><height>30</height>
                    <label>$INFO[ListItem.Property(quality)]</label>
                    <font>font13</font><textcolor>FFffffff</textcolor>
                    <aligny>center</aligny><align>center</align>
                </control>
                <!-- Provider -->
                <control type="label">
                    <left>100</left><top>10</top><width>300</width><height>20</height>
                    <label>$INFO[ListItem.Property(provider)]</label>
                    <font>font10</font><textcolor>FF8888a0</textcolor>
                </control>
                <!-- Sub match -->
                <control type="label">
                    <left>850</left><top>8</top><width>290</width><height>24</height>
                    <label>$INFO[ListItem.Property(sub_display)]</label>
                    <font>font12</font><align>right</align>
                </control>
                <!-- Filename (scrolls when focused) -->
                <control type="label">
                    <left>100</left><top>32</top><width>1040</width><height>22</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font10</font><textcolor>FFeeeeFF</textcolor>
                    <scroll>true</scroll><scrollspeed>60</scrollspeed>
                </control>
                <!-- Tags -->
                <control type="label">
                    <left>100</left><top>56</top><width>800</width><height>18</height>
                    <label>$INFO[ListItem.Property(info_tags)]</label>
                    <font>font10</font><textcolor>FF6666880</textcolor>
                </control>
                <!-- Size row -->
                <control type="label">
                    <left>100</left><top>76</top><width>800</width><height>18</height>
                    <label>$INFO[ListItem.Property(size_display)]</label>
                    <font>font10</font><textcolor>FF555570</textcolor>
                </control>
            </focusedlayout>
        </control>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- RIGHT PANEL: MOVIE INFO                                   -->
        <!-- ══════════════════════════════════════════════════════════ -->

        <!-- Poster with subtle shadow -->
        <control type="image">
            <left>1314</left><top>34</top><width>344</width><height>4</height>
            <texture colordiffuse="22000000">white.png</texture>
        </control>
        <control type="image" id="2000">
            <left>1310</left><top>30</top><width>350</width><height>500</height>
            <aspectratio>keep</aspectratio>
        </control>

        <!-- Title -->
        <control type="label" id="2001">
            <left>1260</left><top>545</top><width>620</width><height>36</height>
            <label></label>
            <font>font14</font><textcolor>FFeeeeFF</textcolor>
            <align>center</align>
        </control>

        <!-- Rating -->
        <control type="label" id="2002">
            <left>1260</left><top>585</top><width>620</width><height>24</height>
