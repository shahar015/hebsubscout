<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol always="true">1000</defaultcontrol>
    <backgroundcolor>FF000000</backgroundcolor>
    <coordinates>
        <system>1</system>
    </coordinates>
    <controls>
        <!-- Full-screen opaque background (5 layers to guarantee opacity) -->
        <control type="image">
            <left>-100</left><top>-100</top><width>2120</width><height>1280</height>
            <texture colordiffuse="FF000000">white.png</texture>
        </control>
        <control type="image">
            <left>-100</left><top>-100</top><width>2120</width><height>1280</height>
            <texture colordiffuse="FF000000">white.png</texture>
        </control>
        <control type="image">
            <left>-100</left><top>-100</top><width>2120</width><height>1280</height>
            <texture colordiffuse="FF000000">white.png</texture>
        </control>
        <control type="image">
            <left>-100</left><top>-100</top><width>2120</width><height>1280</height>
            <texture colordiffuse="FF000000">white.png</texture>
        </control>
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="FF0d0d1a">white.png</texture>
        </control>

        <!-- Filter area: populated dynamically by Python in onInit -->
        <!-- Python creates ControlButton + ControlLabel for each filter row -->
        <!-- IDs 3001-3099 reserved for filter buttons -->
        <!-- IDs 4001-4009 reserved for row labels -->

        <!-- Source count label -->
        <control type="label" id="1001">
            <left>40</left><top>158</top><width>400</width><height>25</height>
            <label></label>
            <font>font10</font><textcolor>FF666688</textcolor>
        </control>

        <!-- Divider line -->
        <control type="image" id="1002">
            <left>40</left><top>185</top><width>1180</width><height>2</height>
            <texture colordiffuse="FF333355">white.png</texture>
        </control>

        <!-- SOURCE LIST (native ControlList with scroll + focus) -->
        <control type="list" id="1000">
            <left>40</left><top>195</top><width>1180</width><height>870</height>
            <viewtype label="sources">list</viewtype>
            <pagecontrol>0</pagecontrol>
            <scrolltime>200</scrolltime>
            <itemgap>6</itemgap>

            <!-- Unfocused card -->
            <itemlayout width="1180" height="100">
                <control type="image">
                    <left>0</left><top>0</top><width>1180</width><height>100</height>
                    <texture colordiffuse="FF111128">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left><top>0</top><width>80</width><height>100</height>
                    <texture colordiffuse="$INFO[ListItem.Property(quality_color)]">white.png</texture>
                </control>
                <control type="label">
                    <left>0</left><top>35</top><width>80</width><height>30</height>
                    <label>$INFO[ListItem.Property(quality)]</label>
                    <font>font12</font><textcolor>FFffffff</textcolor>
                    <aligny>center</aligny><align>center</align>
                </control>
                <control type="label">
                    <left>95</left><top>8</top><width>400</width><height>20</height>
                    <label>$INFO[ListItem.Property(provider)]</label>
                    <font>font10</font><textcolor>FF888888</textcolor>
                </control>
                <control type="label">
                    <left>880</left><top>8</top><width>280</width><height>20</height>
                    <label>$INFO[ListItem.Property(sub_display)]</label>
                    <font>font12</font><align>right</align>
                </control>
                <control type="label">
                    <left>95</left><top>30</top><width>1080</width><height>22</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font10</font><textcolor>FFdddddd</textcolor>
                </control>
                <control type="label">
                    <left>95</left><top>54</top><width>800</width><height>20</height>
                    <label>$INFO[ListItem.Property(info_tags)]</label>
                    <font>font10</font><textcolor>FFaaaaaa</textcolor>
                </control>
                <control type="label">
                    <left>95</left><top>76</top><width>800</width><height>20</height>
                    <label>$INFO[ListItem.Property(size_display)]</label>
                    <font>font10</font><textcolor>FF888888</textcolor>
                </control>
            </itemlayout>

            <!-- Focused card -->
            <focusedlayout width="1180" height="100">
                <control type="image">
                    <left>-2</left><top>-2</top><width>1184</width><height>104</height>
                    <texture colordiffuse="$INFO[ListItem.Property(quality_color)]">white.png</texture>
                    <visible>Control.HasFocus(1000)</visible>
                </control>
                <control type="image">
                    <left>0</left><top>0</top><width>1180</width><height>100</height>
                    <texture colordiffuse="FF1a1a3e">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left><top>0</top><width>80</width><height>100</height>
                    <texture colordiffuse="$INFO[ListItem.Property(quality_color)]">white.png</texture>
                </control>
                <control type="label">
                    <left>0</left><top>35</top><width>80</width><height>30</height>
                    <label>$INFO[ListItem.Property(quality)]</label>
                    <font>font12</font><textcolor>FFffffff</textcolor>
                    <aligny>center</aligny><align>center</align>
                </control>
                <control type="label">
                    <left>95</left><top>8</top><width>400</width><height>20</height>
                    <label>$INFO[ListItem.Property(provider)]</label>
                    <font>font10</font><textcolor>FFcccccc</textcolor>
                </control>
                <control type="label">
                    <left>880</left><top>8</top><width>280</width><height>20</height>
                    <label>$INFO[ListItem.Property(sub_display)]</label>
                    <font>font12</font><align>right</align>
                </control>
                <control type="label">
                    <left>95</left><top>30</top><width>1080</width><height>22</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font10</font><textcolor>FFffffff</textcolor>
                    <scroll>true</scroll><scrollspeed>60</scrollspeed>
                </control>
                <control type="label">
                    <left>95</left><top>54</top><width>800</width><height>20</height>
                    <label>$INFO[ListItem.Property(info_tags)]</label>
                    <font>font10</font><textcolor>FFcccccc</textcolor>
                </control>
                <control type="label">
                    <left>95</left><top>76</top><width>800</width><height>20</height>
                    <label>$INFO[ListItem.Property(size_display)]</label>
                    <font>font10</font><textcolor>FFaaaaaa</textcolor>
                </control>
            </focusedlayout>
        </control>

        <!-- RIGHT PANEL: Movie/Show info -->
        <control type="group">
            <left>1280</left><top>20</top>
            <control type="image" id="2000">
                <left>80</left><top>0</top><width>380</width><height>540</height>
                <aspectratio>keep</aspectratio>
            </control>
            <control type="label" id="2001">
                <left>0</left><top>555</top><width>580</width><height>35</height>
                <label></label><font>font13</font><textcolor>FFffffff</textcolor><align>center</align>
            </control>
            <control type="label" id="2002">
                <left>0</left><top>592</top><width>580</width><height>25</height>
                <label></label><font>font12</font><textcolor>FFf1c40f</textcolor><align>center</align>
            </control>
            <control type="label" id="2003">
                <left>0</left><top>618</top><width>580</width><height>25</height>
                <label></label><font>font10</font><textcolor>FF888888</textcolor><align>center</align>
            </control>
            <control type="textbox" id="2004">
                <left>20</left><top>650</top><width>540</width><height>180</height>
                <font>font10</font><textcolor>FFcccccc</textcolor>
            </control>
            <control type="label" id="2005">
                <left>20</left><top>840</top><width>540</width><height>25</height>
                <label></label><font>font10</font><textcolor>FFaaaaaa</textcolor>
            </control>
            <control type="textbox" id="2006">
                <left>20</left><top>870</top><width>540</width><height>180</height>
                <font>font10</font><textcolor>FFaaaaaa</textcolor>
            </control>
        </control>

    </controls>
</window>
