<?xml version="1.0" encoding="UTF-8"?>
<!-- HebSubScout Netflix Home — RTL-First Layout -->
<window>
	<defaultcontrol>9000</defaultcontrol>
	<backgroundcolor>FF060610</backgroundcolor>
	<controls>

		<!-- Hidden navigation buttons (focus traps → bounce back to content) -->
		<control type="button" id="20000">
			<include>HiddenObject</include>
			<onfocus>SetFocus(9000)</onfocus>
			<onclick>noop</onclick>
			<visible allowhiddenfocus="true">Control.HasFocus(20000)</visible>
		</control>
		<control type="button" id="20001">
			<include>HiddenObject</include>
			<onfocus>SetFocus(9000)</onfocus>
			<onclick>noop</onclick>
			<visible allowhiddenfocus="true">Control.HasFocus(20001)</visible>
		</control>

		<!-- ══════════════════════════════════════════════════════════ -->
		<!-- HERO AREA (top — dynamic fanart from focused widget item) -->
		<!-- ══════════════════════════════════════════════════════════ -->

		<!-- Hero fanart backdrop -->
		<control type="image" id="100">
			<left>0</left><top>0</top><width>1460</width><height>540</height>
			<texture background="true" fallback="fanart.jpg">$VAR[HeroFanartVar]</texture>
			<aspectratio>scale</aspectratio>
			<animation effect="fade" time="400" start="0" end="100">VisibleChange</animation>
		</control>

		<!-- Gradient overlay (transparent top → black bottom) -->
		<control type="image">
			<left>0</left><top>0</top><width>1460</width><height>540</height>
			<texture>gradient_hero.png</texture>
		</control>

		<!-- Dark edge blending into sidebar -->
		<control type="image">
			<left>1360</left><top>0</top><width>100</width><height>540</height>
			<texture colordiffuse="FF060610">white.png</texture>
		</control>

		<!-- Hero title (RTL — right-aligned) -->
		<control type="label" id="102">
			<left>60</left><top>370</top><width>1340</width><height>55</height>
			<label>$VAR[HeroTitleVar]</label>
			<font>font45_title</font>
			<textcolor>FFFFFFFF</textcolor>
			<shadowcolor>CC000000</shadowcolor>
			<align>right</align>
		</control>

		<!-- Hero metadata line (year | rating) -->
		<control type="label" id="103">
			<left>60</left><top>430</top><width>1340</width><height>30</height>
			<label>$VAR[HeroMetaVar]</label>
			<font>font13</font>
			<textcolor>FFaaaacc</textcolor>
			<shadowcolor>CC000000</shadowcolor>
			<align>right</align>
		</control>

		<!-- ══════════════════════════════════════════════════════════ -->
		<!-- SIDEBAR (RIGHT — RTL, 5 tabs)                             -->
		<!-- ══════════════════════════════════════════════════════════ -->

		<!-- Sidebar background panel -->
		<control type="image">
			<left>1460</left><top>0</top><width>460</width><height>1080</height>
			<texture colordiffuse="FF0a0a16">white.png</texture>
		</control>

		<!-- Sidebar accent line -->
		<control type="image">
			<left>1458</left><top>0</top><width>2</width><height>1080</height>
			<texture colordiffuse="FF1a1a2e">white.png</texture>
		</control>

		<!-- Brand label at top of sidebar -->
		<control type="label">
			<left>1480</left><top>40</top><width>420</width><height>40</height>
			<label>HebSubScout</label>
			<font>font30_title</font>
			<textcolor>FF2ecc71</textcolor>
			<align>center</align>
		</control>

		<!-- Sidebar tab list -->
		<control type="fixedlist" id="9000">
			<left>1470</left><top>120</top><width>440</width><height>700</height>
			<orientation>vertical</orientation>
			<movement>1</movement>
			<focusposition>0</focusposition>
			<scrolltime tween="sine">300</scrolltime>
			<onleft>SetFocus($INFO[Container(9000).ListItem.Property(focus_id)])</onleft>
			<onup>20000</onup>
			<ondown>20001</ondown>
			<itemlayout height="95" width="440">
				<control type="image">
					<left>10</left><top>10</top><width>420</width><height>75</height>
					<texture colordiffuse="00000000">white.png</texture>
				</control>
				<control type="label">
					<left>10</left><top>10</top><width>420</width><height>75</height>
					<label>$INFO[ListItem.Label]</label>
					<font>font37</font>
					<textcolor>FF888899</textcolor>
					<align>center</align>
					<aligny>center</aligny>
				</control>
			</itemlayout>
			<focusedlayout height="95" width="440">
				<control type="image">
					<left>10</left><top>10</top><width>420</width><height>75</height>
					<texture colordiffuse="FF1a1a30">white.png</texture>
					<bordertexture border="2" colordiffuse="FF2ecc71">white.png</bordertexture>
				</control>
				<control type="label">
					<left>10</left><top>10</top><width>420</width><height>75</height>
					<label>$INFO[ListItem.Label]</label>
					<font>font37</font>
					<textcolor>FFFFFFFF</textcolor>
					<align>center</align>
					<aligny>center</aligny>
				</control>
				<animation effect="zoom" center="auto" start="100" end="103" time="150" tween="sine">Focus</animation>
			</focusedlayout>
			<content>
				<!-- Tab 1: Home -->
				<item>
					<label>בית</label>
					<property name="id">home</property>
					<property name="menu_id">5000</property>
					<property name="focus_id">5100</property>
					<onclick>SetFocus(5100)</onclick>
				</item>
				<!-- Tab 2: Movies -->
				<item>
					<label>סרטים</label>
					<property name="id">movies</property>
					<property name="menu_id">6000</property>
					<property name="focus_id">6100</property>
					<onclick>SetFocus(6100)</onclick>
				</item>
				<!-- Tab 3: TV Shows -->
				<item>
					<label>סדרות</label>
					<property name="id">tvshows</property>
					<property name="menu_id">7000</property>
					<property name="focus_id">7100</property>
					<onclick>SetFocus(7100)</onclick>
				</item>
				<!-- Tab 4: Search -->
				<item>
					<label>חיפוש</label>
					<property name="id">search</property>
					<property name="menu_id">8000</property>
					<property name="focus_id">8100</property>
					<onclick>SetFocus(8100)</onclick>
				</item>
				<!-- Tab 5: Tools -->
				<item>
					<label>כלים</label>
					<property name="id">tools</property>
					<property name="menu_id">9500</property>
					<property name="focus_id">9510</property>
					<onclick>SetFocus(9510)</onclick>
				</item>
			</content>
		</control>

		<!-- Version label at bottom of sidebar -->
		<control type="label">
			<left>1480</left><top>1030</top><width>420</width><height>25</height>
			<label>v$INFO[System.AddonVersion(plugin.video.hebscout)]</label>
			<font>font10</font>
			<textcolor>FF333344</textcolor>
			<align>center</align>
		</control>

		<!-- ══════════════════════════════════════════════════════════ -->
		<!-- CONTENT AREA (LEFT — widget rows, changes per tab)        -->
		<!-- ══════════════════════════════════════════════════════════ -->

		<control type="group" id="2000">
			<left>0</left><top>480</top><width>1460</width><height>600</height>

			<!-- ── בית (Home) — Group 5000 ── -->
			<control type="group" id="5000">
				<visible>String.IsEqual(Container(9000).ListItem.Property(id),home)</visible>
				<animation effect="fade" time="300" start="0" end="100">VisibleChange</animation>
				<control type="grouplist" id="5001">
					<include>WidgetGroupListCommon</include>
					<pagecontrol>5010</pagecontrol>
					<onright>9000</onright>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=continue_watching"/>
						<param name="widget_header" value="המשך צפייה"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="5100"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=movies_trending"/>
						<param name="widget_header" value="סרטים טרנדינג"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="5200"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=shows_popular"/>
						<param name="widget_header" value="סדרות פופולריות"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="5300"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=trakt_next_up"/>
						<param name="widget_header" value="פרק הבא"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="5400"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=trakt_watchlist_movies"/>
						<param name="widget_header" value="הרשימה שלי"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="5500"/>
					</include>
				</control>
			</control>

			<!-- ── סרטים (Movies) — Group 6000 ── -->
			<control type="group" id="6000">
				<visible>String.IsEqual(Container(9000).ListItem.Property(id),movies)</visible>
				<animation effect="fade" time="300" start="0" end="100">VisibleChange</animation>
				<control type="grouplist" id="6001">
					<include>WidgetGroupListCommon</include>
					<pagecontrol>6010</pagecontrol>
					<onright>9000</onright>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=movies_trending"/>
						<param name="widget_header" value="טרנדינג"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="6100"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=movies_popular"/>
						<param name="widget_header" value="פופולרי"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="6200"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=movies_top_rated"/>
						<param name="widget_header" value="מדורג"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="6300"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=movies_now_playing"/>
						<param name="widget_header" value="עכשיו בקולנוע"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="6400"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=movies_upcoming"/>
						<param name="widget_header" value="בקרוב"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="6500"/>
					</include>
				</control>
			</control>

			<!-- ── סדרות (TV Shows) — Group 7000 ── -->
			<control type="group" id="7000">
				<visible>String.IsEqual(Container(9000).ListItem.Property(id),tvshows)</visible>
				<animation effect="fade" time="300" start="0" end="100">VisibleChange</animation>
				<control type="grouplist" id="7001">
					<include>WidgetGroupListCommon</include>
					<pagecontrol>7010</pagecontrol>
					<onright>9000</onright>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=shows_trending"/>
						<param name="widget_header" value="טרנדינג"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="7100"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=shows_popular"/>
						<param name="widget_header" value="פופולרי"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="7200"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=shows_top_rated"/>
						<param name="widget_header" value="מדורג"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="7300"/>
					</include>
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=shows_airing_today"/>
						<param name="widget_header" value="משודר היום"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="7400"/>
					</include>
				</control>
			</control>

			<!-- ── חיפוש (Search) — Group 8000 ── -->
			<control type="group" id="8000">
				<visible>String.IsEqual(Container(9000).ListItem.Property(id),search)</visible>
				<animation effect="fade" time="300" start="0" end="100">VisibleChange</animation>
				<control type="grouplist" id="8001">
					<include>WidgetGroupListCommon</include>
					<pagecontrol>8010</pagecontrol>
					<onright>9000</onright>
					<!-- Search button — opens input dialog -->
					<control type="button" id="8100">
						<left>55</left>
						<width>400</width><height>60</height>
						<texturefocus colordiffuse="FF2ecc71">white.png</texturefocus>
						<texturenofocus colordiffuse="FF1a1a30">white.png</texturenofocus>
						<label>חיפוש...</label>
						<font>font14</font>
						<textcolor>FFFFFFFF</textcolor>
						<focusedcolor>FF000000</focusedcolor>
						<align>center</align>
						<aligny>center</aligny>
						<onclick>RunPlugin(plugin://plugin.video.hebscout/?action=home_search)</onclick>
					</control>
					<!-- Movie search results row -->
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=search_widget_movies"/>
						<param name="widget_header" value="סרטים"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="8200"/>
					</include>
					<!-- Show search results row -->
					<include content="WidgetListPoster">
						<param name="content_path" value="plugin://plugin.video.hebscout/?action=search_widget_shows"/>
						<param name="widget_header" value="סדרות"/>
						<param name="widget_target" value="videos"/>
						<param name="list_id" value="8300"/>
					</include>
				</control>
			</control>

			<!-- ── כלים (Tools) — Group 9500 ── -->
			<control type="group" id="9500">
				<visible>String.IsEqual(Container(9000).ListItem.Property(id),tools)</visible>
				<animation effect="fade" time="300" start="0" end="100">VisibleChange</animation>
				<control type="grouplist" id="9501">
					<orientation>vertical</orientation>
					<left>60</left><top>30</top><width>1340</width><height>500</height>
					<itemgap>10</itemgap>
					<onright>9000</onright>
					<control type="button" id="9510">
						<width>400</width><height>50</height>
						<texturefocus colordiffuse="FF2ecc71">white.png</texturefocus>
						<texturenofocus colordiffuse="FF1a1a30">white.png</texturenofocus>
						<label>Real Debrid</label>
						<font>font14</font>
						<textcolor>FFFFFFFF</textcolor>
						<focusedcolor>FF000000</focusedcolor>
						<align>center</align><aligny>center</aligny>
						<onclick>RunPlugin(plugin://plugin.video.hebscout/?action=rd_auth)</onclick>
					</control>
					<control type="button" id="9520">
						<width>400</width><height>50</height>
						<texturefocus colordiffuse="FF3498db">white.png</texturefocus>
						<texturenofocus colordiffuse="FF1a1a30">white.png</texturenofocus>
						<label>Trakt</label>
						<font>font14</font>
						<textcolor>FFFFFFFF</textcolor>
						<focusedcolor>FFFFFFFF</focusedcolor>
						<align>center</align><aligny>center</aligny>
						<onclick>RunPlugin(plugin://plugin.video.hebscout/?action=trakt_auth)</onclick>
					</control>
					<control type="button" id="9530">
						<width>400</width><height>50</height>
						<texturefocus colordiffuse="FFe67e22">white.png</texturefocus>
						<texturenofocus colordiffuse="FF1a1a30">white.png</texturenofocus>
						<label>הגדרות</label>
						<font>font14</font>
						<textcolor>FFFFFFFF</textcolor>
						<focusedcolor>FFFFFFFF</focusedcolor>
						<align>center</align><aligny>center</aligny>
						<onclick>ActivateWindow(settings)</onclick>
					</control>
					<control type="button" id="9540">
						<width>400</width><height>50</height>
						<texturefocus colordiffuse="FFe74c3c">white.png</texturefocus>
						<texturenofocus colordiffuse="FF1a1a30">white.png</texturenofocus>
						<label>נקה מטמון</label>
						<font>font14</font>
						<textcolor>FFFFFFFF</textcolor>
						<focusedcolor>FFFFFFFF</focusedcolor>
						<align>center</align><aligny>center</aligny>
						<onclick>RunPlugin(plugin://plugin.video.hebscout/?action=clear_cache)</onclick>
					</control>
				</control>
			</control>

		</control>

	</controls>
</window>
